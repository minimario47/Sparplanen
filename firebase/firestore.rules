rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────────
    // Önskemål — user feature requests / bug reports / improvement ideas.
    //
    // Anyone using the app may SUBMIT one (create), with no sign-in. Nobody can
    // read, edit or delete submissions from a client — you read them in the
    // Firebase console (Firestore → onskemal collection). The Cloud Functions
    // (firebase-admin) bypass these rules entirely, so they are unaffected.
    //
    // Creates are validated to keep junk/abuse bounded: a fixed set of fields,
    // a non-empty bounded message, and a server-stamped createdAt.
    // ──────────────────────────────────────────────────────────────────────
    match /onskemal/{docId} {
      allow create: if
        request.resource.data.keys().hasOnly(['type', 'message', 'contact', 'createdAt', 'page', 'userAgent'])
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 2000
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 40
        && (!('contact' in request.resource.data) || (request.resource.data.contact is string && request.resource.data.contact.size() <= 200))
        && (!('page' in request.resource.data) || (request.resource.data.page is string && request.resource.data.page.size() <= 300))
        && (!('userAgent' in request.resource.data) || (request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 500))
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    // Everything else: no client access. Admin SDK (Cloud Functions) bypasses
    // this, so server-side reads/writes keep working.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
